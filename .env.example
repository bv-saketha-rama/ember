# ─────────────────────────────────────────────────────────────
# Ember — environment variables
# Copy to `.env.local` and fill in. NEVER commit real secrets.
# ─────────────────────────────────────────────────────────────

# ── Convex (backend) ───────────────────────────────────────────
# Created automatically by `npx convex dev`. Do not set by hand.
CONVEX_DEPLOYMENT=

# Your Convex deployment URLs (printed by `npx convex dev`).
NEXT_PUBLIC_CONVEX_URL=https://your-deployment.convex.cloud
NEXT_PUBLIC_CONVEX_SITE_URL=https://your-deployment.convex.site

# ── Clerk (auth) ───────────────────────────────────────────────
# From the Clerk dashboard → API keys. Enable ONLY Email + Google.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_<your-publishable-key>
CLERK_SECRET_KEY=sk_test_<your-clerk-secret-key>

# Keep auth INSIDE the app (embedded pages + modals), never Clerk's
# hosted Account Portal. These four should be left exactly as-is.
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# ─────────────────────────────────────────────────────────────
# The two variables below are SERVER-SIDE ONLY and live in Convex,
# not in this file. Set them with the Convex CLI so they are never
# shipped to the browser:
#
#   npx convex env set CLERK_JWT_ISSUER_DOMAIN https://<your-subdomain>.clerk.accounts.dev
#   npx convex env set GEMINI_API_KEY <your-gemini-key>
#
# CLERK_JWT_ISSUER_DOMAIN  — issuer for the "convex" JWT template.
# GEMINI_API_KEY           — Google AI Studio key (gemini-2.5-flash).
#                            Used only inside Convex actions; the key
#                            is NEVER exposed to the client.
# ─────────────────────────────────────────────────────────────
